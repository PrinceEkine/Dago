<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dago_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_settings"
            android:textColor="@color/dago_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_tor_title"
            android:textColor="@color/dago_text"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/torStatusDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_adblock_title"
            android:textColor="@color/dago_text"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/adblockStatusDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Search engine"
            android:textColor="@color/dago_text"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Used when you type a search query into the address bar. Add your own with any https:// URL containing %s as the query placeholder."
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/searchProviderRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/newProviderName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Name"
                android:textColor="@color/dago_text" />

            <EditText
                android:id="@+id/newProviderUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="https://example.com/search?q=%s"
                android:textColor="@color/dago_text" />

            <Button
                android:id="@+id/addProviderButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add" />
        </LinearLayout>

        <TextView
            android:id="@+id/searchProviderError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dago_danger" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_filter_lists_title"
                android:textColor="@color/dago_text"
                android:textSize="14sp" />

            <Button
                android:id="@+id/updateAllButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Update all" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_filter_lists_desc"
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/filterListRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/newListName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Name"
                android:textColor="@color/dago_text" />

            <EditText
                android:id="@+id/newListUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="https://example.com/list.txt"
                android:textColor="@color/dago_text" />

            <Button
                android:id="@+id/addListButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add" />
        </LinearLayout>

        <TextView
            android:id="@+id/filterListError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dago_danger" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="History PIN"
                android:textColor="@color/dago_text"
                android:textSize="14sp" />

            <Button
                android:id="@+id/resetPinButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset PIN" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_camera_title"
            android:textColor="@color/dago_text"
            android:textSize="14sp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_camera_desc"
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_version_title"
            android:textColor="@color/dago_text"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/versionDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dago_text_muted"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />
    </LinearLayout>
</ScrollView>
